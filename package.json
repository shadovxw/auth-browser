{
  "name": "@shadovxw/auth-browser",
  "version": "0.1.2",
  "description": "Bastion auth SDK for Next.js apps on shadovxw.me",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "next": "^15.0.0",
    "react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "tsup": {
    "entry": {
      "index": "src/index.ts",
      "server": "src/server.ts"
    },
    "format": [
      "cjs",
      "esm"
    ],
    "dts": true,
    "external": [
      "next",
      "react",
      "react-dom"
    ],
    "banner": {
      "js": ""
    }
  }
}
